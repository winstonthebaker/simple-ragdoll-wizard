[sub_resource type="GDScript" id="GDScript_x711q"]
script/source = "@tool
class_name RagdollBoneConfigggg
extends Resource


enum ColliderType {BOX, CAPSULE}
enum JointType {HINGE, CONE_TWIST}

@export var bone_name: String = \"\"

@export var collider_type: ColliderType = ColliderType.CAPSULE
@export var joint_type: JointType = JointType.CONE_TWIST

@export var box_extents: Vector3 = Vector3(1.0, 1.0, 1.0)
@export var capsule_shape: Vector2 = Vector2(0.3, 1.0)
"

